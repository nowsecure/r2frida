NAME=breakpoints empty list
FILE=frida://0
CMDS=<<EOF
:db
:dbj
EOF
EXPECT=<<EOF
No breakpoints set
{}
EOF
RUN

NAME=software breakpoint set unset
FILE=frida://0
CMDS=<<EOF
:e dbg.hwbp=false
:db puts
:db~(sw)?
:db- puts
:db
EOF
EXPECT=<<EOF
Breakpoint at puts set
1
Breakpoint at puts unset
No breakpoints set
EOF
RUN

NAME=dcu keeps temporary breakpoint until hit
FILE=frida://0
CMDS=<<EOF
:e dbg.hwbp=false
:dcu puts
:db~(sw)?
EOF
EXPECT=<<EOF
Continue thread(s).
1
EOF
RUN

NAME=watchpoint rw condition
FILE=frida://0
CMDS=<<EOF
:dbw puts 1 rw
:dbwj~{condition}
:dbw- puts
EOF
EXPECT=<<EOF
Watchpoint at puts set
rw
Watchpoint at puts unset
EOF
RUN
